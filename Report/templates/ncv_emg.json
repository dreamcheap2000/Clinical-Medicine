{
  "examType": "ncv_emg",
  "version": "1.0.0",
  "title": "Nerve Conduction Velocity (NCV) / Electromyography (EMG)",
  "changelog": [
    { "version": "1.0.0", "date": "2026-04-13", "note": "Initial template" }
  ],
  "sections": [
    {
      "id": "patient",
      "label": "Patient Information",
      "fields": [
        { "id": "patient_id",   "label": "Patient ID",         "type": "text",     "required": true },
        { "id": "patient_name", "label": "Patient Name",       "type": "text",     "required": true },
        { "id": "dob",          "label": "Date of Birth",      "type": "date",     "required": true },
        { "id": "exam_date",    "label": "Exam Date",          "type": "date",     "required": true },
        { "id": "indication",   "label": "Clinical Indication","type": "textarea", "required": true }
      ]
    },
    {
      "id": "motor_ncv",
      "label": "Motor Nerve Conduction Studies",
      "fields": [
        {
          "id": "motor_nerves_tested",
          "label": "Motor Nerves Tested",
          "type": "multiselect",
          "choices": [
            "Median (right)", "Median (left)",
            "Ulnar (right)", "Ulnar (left)",
            "Radial (right)", "Radial (left)",
            "Common peroneal / fibular (right)", "Common peroneal / fibular (left)",
            "Tibial (right)", "Tibial (left)",
            "Facial (right)", "Facial (left)"
          ]
        },
        {
          "id": "motor_latency_finding",
          "label": "Distal Motor Latency",
          "type": "select",
          "choices": ["Normal", "Mildly prolonged", "Moderately prolonged", "Severely prolonged", "Absent"]
        },
        {
          "id": "motor_amplitude_finding",
          "label": "Motor CMAP Amplitude",
          "type": "select",
          "choices": ["Normal", "Mildly reduced", "Moderately reduced", "Severely reduced", "Absent"]
        },
        {
          "id": "motor_velocity_finding",
          "label": "Motor Nerve Conduction Velocity",
          "type": "select",
          "choices": ["Normal", "Mildly slow", "Moderately slow", "Severely slow", "Not measurable"]
        },
        {
          "id": "motor_f_wave",
          "label": "F-Wave",
          "type": "select",
          "choices": ["Normal", "Prolonged", "Absent", "Not tested"]
        },
        {
          "id": "motor_conduction_block",
          "label": "Conduction Block",
          "type": "select",
          "choices": ["None", "Partial conduction block", "Complete conduction block"]
        }
      ]
    },
    {
      "id": "sensory_ncv",
      "label": "Sensory Nerve Conduction Studies",
      "fields": [
        {
          "id": "sensory_nerves_tested",
          "label": "Sensory Nerves Tested",
          "type": "multiselect",
          "choices": [
            "Median (right)", "Median (left)",
            "Ulnar (right)", "Ulnar (left)",
            "Radial (right)", "Radial (left)",
            "Sural (right)", "Sural (left)",
            "Superficial peroneal / fibular (right)", "Superficial peroneal / fibular (left)",
            "Medial plantar (right)", "Medial plantar (left)"
          ]
        },
        {
          "id": "sensory_latency_finding",
          "label": "Sensory Peak Latency",
          "type": "select",
          "choices": ["Normal", "Mildly prolonged", "Moderately prolonged", "Severely prolonged", "Absent"]
        },
        {
          "id": "sensory_amplitude_finding",
          "label": "Sensory SNAP Amplitude",
          "type": "select",
          "choices": ["Normal", "Mildly reduced", "Moderately reduced", "Severely reduced", "Absent"]
        },
        {
          "id": "sensory_velocity_finding",
          "label": "Sensory Conduction Velocity",
          "type": "select",
          "choices": ["Normal", "Mildly slow", "Moderately slow", "Severely slow", "Not measurable"]
        }
      ]
    },
    {
      "id": "emg",
      "label": "Needle EMG",
      "fields": [
        {
          "id": "emg_muscles_tested",
          "label": "Muscles Examined",
          "type": "multiselect",
          "choices": [
            "Biceps (right)", "Biceps (left)",
            "Triceps (right)", "Triceps (left)",
            "First dorsal interosseous (right)", "First dorsal interosseous (left)",
            "Abductor pollicis brevis (right)", "Abductor pollicis brevis (left)",
            "Deltoid (right)", "Deltoid (left)",
            "Tibialis anterior (right)", "Tibialis anterior (left)",
            "Gastrocnemius (right)", "Gastrocnemius (left)",
            "Vastus medialis (right)", "Vastus medialis (left)",
            "Paraspinals (cervical)", "Paraspinals (thoracic)", "Paraspinals (lumbar)"
          ]
        },
        {
          "id": "emg_insertional_activity",
          "label": "Insertional Activity",
          "type": "select",
          "choices": ["Normal", "Increased (fibrillations / PSW)", "Decreased (chronic / fibrosis)", "Myotonic discharges"]
        },
        {
          "id": "emg_spontaneous_activity",
          "label": "Spontaneous Activity at Rest",
          "type": "multiselect",
          "choices": [
            "None",
            "Fibrillation potentials",
            "Positive sharp waves (PSW)",
            "Fasciculation potentials",
            "Complex repetitive discharges (CRD)",
            "Myotonic discharges",
            "Neuromyotonic discharges",
            "Cramp discharges"
          ]
        },
        {
          "id": "emg_muap",
          "label": "Motor Unit Action Potentials (MUAP)",
          "type": "select",
          "choices": ["Normal", "Long duration / large amplitude (neurogenic)", "Short duration / small amplitude (myopathic)", "Mixed", "Absent"]
        },
        {
          "id": "emg_recruitment",
          "label": "Recruitment Pattern",
          "type": "select",
          "choices": ["Normal", "Reduced (neurogenic)", "Early full recruitment (myopathic)", "Single MU firing rapidly (severe axon loss)", "Absent"]
        }
      ]
    },
    {
      "id": "pattern",
      "label": "Electrophysiological Pattern",
      "fields": [
        {
          "id": "ncv_pattern",
          "label": "Overall NCV/EMG Pattern",
          "type": "select",
          "required": true,
          "choices": [
            "Normal",
            "Axonal polyneuropathy",
            "Demyelinating polyneuropathy",
            "Mixed axonal-demyelinating polyneuropathy",
            "Mononeuropathy",
            "Multiple mononeuropathy (mononeuritis multiplex)",
            "Radiculopathy",
            "Plexopathy",
            "Neuromuscular junction disorder",
            "Myopathy",
            "Motor neuron disease pattern"
          ]
        },
        {
          "id": "distribution",
          "label": "Distribution",
          "type": "select",
          "choices": ["Distal > proximal", "Proximal > distal", "Diffuse / symmetric", "Asymmetric / focal", "Length-dependent", "Non-length-dependent"]
        },
        {
          "id": "fibre_type",
          "label": "Fibre Type Affected",
          "type": "select",
          "choices": ["Motor only", "Sensory only", "Sensorimotor", "Small fibre (clinical, NCS normal)"]
        }
      ]
    },
    {
      "id": "impression",
      "label": "Impression",
      "fields": [
        {
          "id": "impression_text",
          "label": "Impression",
          "type": "textarea",
          "required": true
        }
      ]
    }
  ],
  "abnormality_rules": [
    { "field": "ncv_pattern", "not_equals": "Normal", "classify": "Abnormal NCV/EMG" },
    { "field": "ncv_pattern", "contains": "Axonal", "classify": "Axonal Neuropathy" },
    { "field": "ncv_pattern", "contains": "Demyelinating", "classify": "Demyelinating Neuropathy" },
    { "field": "ncv_pattern", "contains": "Motor neuron disease", "classify": "Motor Neuron Disease Pattern" },
    { "field": "ncv_pattern", "contains": "Myopathy", "classify": "Myopathy" },
    { "field": "ncv_pattern", "contains": "Neuromuscular junction", "classify": "NMJ Disorder" },
    { "field": "emg_spontaneous_activity", "contains": "Fasciculation potentials", "classify": "Fasciculations (MND Concern)" },
    { "field": "motor_conduction_block", "in": ["Partial conduction block", "Complete conduction block"], "classify": "Conduction Block (Demyelinating)" },
    { "field": "motor_amplitude_finding", "in": ["Severely reduced", "Absent"], "classify": "Severe Axon Loss" }
  ]
}

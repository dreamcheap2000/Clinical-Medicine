{
  "examType": "ultrasound_injection",
  "version": "1.0.0",
  "title": "Ultrasound-Guided Injection",
  "changelog": [
    { "version": "1.0.0", "date": "2026-04-13", "note": "Initial template" }
  ],
  "sections": [
    {
      "id": "patient",
      "label": "Patient Information",
      "fields": [
        { "id": "patient_id",   "label": "Patient ID",        "type": "text",   "required": true },
        { "id": "patient_name", "label": "Patient Name",      "type": "text",   "required": true },
        { "id": "dob",          "label": "Date of Birth",     "type": "date",   "required": true },
        { "id": "exam_date",    "label": "Exam Date",         "type": "date",   "required": true },
        { "id": "indication",   "label": "Clinical Indication","type": "textarea","required": true }
      ]
    },
    {
      "id": "procedure",
      "label": "Procedure Details",
      "fields": [
        {
          "id": "target_site",
          "label": "Target Site",
          "type": "select",
          "required": true,
          "choices": [
            "Shoulder (glenohumeral joint)",
            "Shoulder (subacromial bursa)",
            "Shoulder (AC joint)",
            "Elbow (joint)",
            "Elbow (lateral epicondyle)",
            "Elbow (medial epicondyle)",
            "Wrist (joint)",
            "Hip (joint)",
            "Hip (greater trochanteric bursa)",
            "Knee (joint)",
            "Knee (pes anserine bursa)",
            "Ankle (joint)",
            "Carpal tunnel (nerve sheath)",
            "Trigger point",
            "Other"
          ]
        },
        {
          "id": "target_side",
          "label": "Side",
          "type": "select",
          "choices": ["Left", "Right", "Bilateral", "N/A"]
        },
        {
          "id": "needle_approach",
          "label": "Needle Approach",
          "type": "select",
          "choices": ["In-plane", "Out-of-plane", "Combined"]
        },
        {
          "id": "needle_gauge",
          "label": "Needle Gauge",
          "type": "select",
          "choices": ["18G", "21G", "22G", "23G", "25G", "27G"]
        },
        {
          "id": "substance_injected",
          "label": "Substance Injected",
          "type": "multiselect",
          "choices": [
            "Corticosteroid (triamcinolone)",
            "Corticosteroid (methylprednisolone)",
            "Corticosteroid (dexamethasone)",
            "Local anaesthetic (lidocaine)",
            "Local anaesthetic (bupivacaine)",
            "Normal saline",
            "Hyaluronic acid",
            "Platelet-rich plasma (PRP)",
            "Dextrose (prolotherapy)",
            "Botulinum toxin"
          ]
        },
        {
          "id": "volume_ml",
          "label": "Volume Injected (mL)",
          "type": "number",
          "min": 0,
          "max": 50
        },
        {
          "id": "guidance_quality",
          "label": "Ultrasound Guidance Quality",
          "type": "select",
          "choices": ["Excellent", "Good", "Fair", "Poor"]
        },
        {
          "id": "needle_visibility",
          "label": "Needle Visibility",
          "type": "select",
          "choices": ["Fully visible", "Partially visible", "Tip visible only"]
        }
      ]
    },
    {
      "id": "findings",
      "label": "Ultrasound Findings",
      "fields": [
        {
          "id": "pre_injection_findings",
          "label": "Pre-Injection Findings",
          "type": "multiselect",
          "choices": [
            "Normal",
            "Effusion",
            "Synovial thickening",
            "Tendinopathy",
            "Partial tear",
            "Full-thickness tear",
            "Calcification",
            "Bursitis",
            "Nerve thickening",
            "Increased vascularity (power Doppler)"
          ]
        },
        {
          "id": "fluid_aspiration",
          "label": "Fluid Aspiration",
          "type": "select",
          "choices": ["None", "Serous", "Serosanguinous", "Haemorrhagic", "Purulent", "Viscous (mucoid)"]
        },
        {
          "id": "aspiration_volume_ml",
          "label": "Aspiration Volume (mL)",
          "type": "number",
          "min": 0
        }
      ]
    },
    {
      "id": "outcome",
      "label": "Outcome & Complications",
      "fields": [
        {
          "id": "immediate_outcome",
          "label": "Immediate Outcome",
          "type": "select",
          "choices": ["Successful — confirmed intra-articular/target placement", "Successful — clinical relief", "Partial success", "Unsuccessful"]
        },
        {
          "id": "complications",
          "label": "Complications",
          "type": "multiselect",
          "choices": ["None", "Vasovagal", "Haematoma", "Infection risk", "Tendon injury", "Nerve injury", "Anaphylaxis"]
        },
        {
          "id": "post_procedure_plan",
          "label": "Post-Procedure Plan",
          "type": "textarea"
        }
      ]
    },
    {
      "id": "impression",
      "label": "Impression",
      "fields": [
        {
          "id": "impression_text",
          "label": "Impression",
          "type": "textarea",
          "required": true
        }
      ]
    }
  ],
  "abnormality_rules": [
    { "field": "pre_injection_findings", "contains": "Full-thickness tear",   "classify": "Full-Thickness Tear" },
    { "field": "pre_injection_findings", "contains": "Partial tear",           "classify": "Partial Tear" },
    { "field": "pre_injection_findings", "contains": "Tendinopathy",           "classify": "Tendinopathy" },
    { "field": "pre_injection_findings", "contains": "Bursitis",               "classify": "Bursitis" },
    { "field": "pre_injection_findings", "contains": "Nerve thickening",       "classify": "Nerve Pathology" },
    { "field": "pre_injection_findings", "contains": "Calcification",          "classify": "Calcific Tendinitis" },
    { "field": "fluid_aspiration",       "equals":   "Purulent",               "classify": "Septic Arthritis Suspected" },
    { "field": "complications",          "not_contains": "None",               "classify": "Complication Recorded" }
  ]
}
